---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="header" style="display: flex">
	<nav class="header-left-group sl-flex" style="flex: 1"  aria-label="主导航">
		<div class="title-wrapper sl-flex">
			<SiteTitle />
		</div>
		<a href="/docs/get-started/introduction/" class="header-nav-link" style="margin-inline-start:1.5rem;">文档</a>
		<a href="/posts/engineering/demo-context-budget/" class="header-nav-link">工程</a>
		<a href="/posts/product/demo-introducing-peri/" class="header-nav-link">产品</a>
		<a href="/posts/research/demo-domestic-models/" class="header-nav-link">研究</a>
		<a href="/posts/news/demo-v2-release/" class="header-nav-link">动态</a>
	</nav>
	<div class="sl-hidden md:sl-flex print:hidden right-group">
		<div class="sl-flex social-icons">
			<SocialIcons />
		</div>
		<ThemeSelect />
		<LanguageSelect />
	</div>
</div>

<style>
	@layer starlight.core {
		.header-left-group {
			align-items: center;
			gap: 0;
		}
		.header-nav-link {
			display: none;
			align-items: center;
			font-size: var(--sl-text-sm);
			font-weight: 500;
			color: var(--sl-color-gray-2);
			text-decoration: none;
			padding: 0.35rem 0.75rem;
			border-radius: 0.5rem;
			margin-inline-start: 0.25rem;
			transition: color 0.2s, background 0.2s;
		}
		.header-nav-link:hover {
			color: var(--sl-color-white);
			background: var(--sl-color-gray-6);
		}
		@media (min-width: 50rem) {
			.header-nav-link {
				display: inline-flex;
			}
		}
	}
</style>
